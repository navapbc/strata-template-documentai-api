{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>navapbc/strata-lib-renovate:strataTemplate"
  ],
  "packageRules": [
    {
      "groupName": "Python language",
      "groupSlug": "python-lang",
      "matchManagers": [
        "pip_requirements",
        "dockerfile",
        "custom.regex",
        "python-version"
      ],
      "matchDatasources": [
        "docker",
        "pypi",
        "python-version"
      ],
      "matchDepNames": [
        "python",
        "registry.docker.com/library/python"
      ],
      "commitMessageTopic": "Python language"
    }
  ]
}
