{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "customManagers:dockerfileVersions",
    "schedule:monthly",
    ":maintainLockFilesMonthly"
  ],
  "labels": [
    "dependencies"
  ],
  "github-actions": {
    "fileMatch": [
      "^template/\\.github/(?:workflows|actions)/.+\\.ya?ml(?:.jinja)?$"
    ]
  },
  "packageRules": [
    {
      "groupName": "{{manager}} non-major dependencies",
      "groupSlug": "{{manager}}-minor-patch",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "groupName": "Python language",
      "groupSlug": "python-lang",
      "matchManagers": [
        "pip_requirements",
        "dockerfile",
        "custom.regex",
        "python-version"
      ],
      "matchDatasources": [
        "docker",
        "pypi",
        "python-version"
      ],
      "matchDepNames": [
        "python",
        "registry.docker.com/library/python"
      ],
      "commitMessageTopic": "Python language"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ]
  }
}
