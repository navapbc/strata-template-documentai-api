architecture-beta
    group api(logos:aws-vpc)[API Layer]
    group processing(logos:aws-vpc)[Processing]
    group analytics(logos:aws-vpc)[Analytics]

    service alb(logos:aws-elb)[ALB] in api
    service ecs(logos:aws-ecs)[FastAPI] in api
    
    service s3input(logos:aws-s3)[S3 Input] in processing
    service document-processor(logos:aws:arch-aws-step-functions)[Document Processor] in processing
    service ddb(logos:aws-dynamodb)[DynamoDB] in processing
    service bedrock(logos:aws:arch-amazon-bedrock)[Bedrock Data Analytics] in processing
    service s3output(logos:aws-s3)[S3 Output] in processing
    service bda-output-processor(logos:aws:arch-aws-step-functions)[BDA Output Processor] in processing
    service sqs(logos:aws:arch-amazon-simple-queue-service)[Completed Processing Queue] in analytics
    service glue(logos:aws-glue)[Glue] in analytics
    service s3glue(logos:aws-s3)[Glue Input] in analytics
    service athena(logos:aws-athena)[Athena] in analytics


    alb:R --> L:ecs
    ecs:R --> L:s3input
    ecs:R <--> L:ddb
    s3input:R --> L:document-processor
    document-processor:B --> T:ddb
    document-processor:R --> L:bedrock
    bedrock:B --> T:s3output
    s3output:L --> R:bda-output-processor
    bda-output-processor:T --> B:ddb
    bda-output-processor:B --> T:sqs
    sqs:R --> L:s3glue
    s3glue:R --> L:glue
    glue:R --> L:athena