{
  "api": {
    "version": "v1",
    "default_timeout": 30
  },
  "file_validation": {
    "supported_content_types": [
      "application/pdf",
      "image/jpeg",
      "image/png",
      "image/tiff"
    ]
  },
  "document_categories": [
    "income",
    "expenses",
    "legal_documents",
    "employment_training"
  ],
  "upload_metadata_keys": {
    "user_provided_document_category": "user-provided-document-category",
    "job_id": "job-id",
    "trace_id": "trace-id"
  }
}