.PHONY: \
	build \
	check \
	clean \
	clean-volumes \
	format \
	format-check \
	help \
	init \
	init-clean \
	init-local \
	lint \
	lint-ci \
	login \
	release-build \
	run-logs \
	start \
	start-local \
	stop \
	test

.DEFAULT_GOAL := help

# Check that given variables are set and all have non-empty values,
# die with an error otherwise.
#
# Params:
#   1. Variable name(s) to test.
#   2. (optional) Error message to print.
# Based off of https://stackoverflow.com/questions/10858261/how-to-abort-makefile-if-variable-not-set
check_defined = \
	$(strip $(foreach 1,$1, \
        $(call __check_defined,$1,$(strip $(value 2)))))
__check_defined = \
	$(if $(value $1),, \
		$(error Undefined $1$(if $2, ($2))$(if $(value @), \
			required by target '$@')))


##################################################
# Constants
##################################################

APP_NAME := {{app_name}}

# By default, all python/uv commands will run inside of the docker container
# if you wish to run this natively, add PY_RUN_APPROACH=local to your environment vars
# You can set this by either running `export PY_RUN_APPROACH=local` in your shell or add
# it to your ~/.zshrc file (and run `source ~/.zshrc`)
ifeq "$(PY_RUN_APPROACH)" "local"
PY_RUN_CMD := uv run
else
PY_RUN_CMD := docker compose run $(DOCKER_EXEC_ARGS) --rm $(APP_NAME) uv run
endif


##################################################
# Build & Run
##################################################

build: ## Build Docker containers
	docker compose build

start: ## Start containers in detached mode
	docker compose up --detach

start-local: ## Run the application server natively
	uv run documentai_api

run-logs: start ## Start containers and follow logs
	docker compose logs --follow --no-color $(APP_NAME)

init: ## Initialize project (container-based)
	docker compose build

init-clean: ## Initialize project with fresh volumes
	docker compose down -v
	docker compose build

init-local: ## Initialize project for native development
	uv sync --all-extras

clean-volumes: ## Remove project docker volumes
	docker compose down --volumes

stop: ## Stop containers
	docker compose down

check: format-check lint test ## Run all checks

release-build: ## Build production Docker image
	docker buildx build \
		--platform=linux/amd64 \
		$(OPTS) \
		.

##################################################
# Testing
##################################################

test: ## Run test suite
	$(PY_RUN_CMD) pytest

# TODO: Enable coverage enforcement once PR #14 is merged
# test-coverage: ## Run test suite with coverage report
# 	$(PY_RUN_CMD) pytest --cov=documentai_api --cov-report=term --cov-report=html --cov-fail-under=90

##################################################
# Lint / Format
##################################################

format: ## Format code
	$(PY_RUN_CMD) ruff format .

format-check: ## check format without modifying
	$(PY_RUN_CMD) ruff format --check

lint: ## Lint code
	$(PY_RUN_CMD) ruff check --fix .

lint-ci: ## Lint code (CI mode, no fixes)
	$(PY_RUN_CMD) ruff check --no-fix .


##################################################
# Miscellaneous Utilities
##################################################

login: start ## Start shell in running container
	docker exec -it $(APP_NAME) bash

clean: ## Clean build artifacts
	rm -rf .pytest_cache htmlcov .coverage __pycache__
	find . -type d -name "__pycache__" -exec rm -rf {} +

help: ## Show help
	@grep -Eh '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-20s\033[0m %s\n", $$1, $$2}'
	@echo ""
	@echo "APP_NAME=$(APP_NAME)"
