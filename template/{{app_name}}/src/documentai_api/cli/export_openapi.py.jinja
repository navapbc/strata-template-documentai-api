import json
import sys
from pathlib import Path

ROOT_DIR = Path(__file__).resolve().parents[2]
DOCS_DIR = ROOT_DIR / "docs" / "{{app_name}}"
DEFAULT_FILE_NAME = "openapi.json"
sys.path.append(str(ROOT_DIR / "src"))

try:
    from documentai_api.app import app
except ImportError as e:
    print(f"Error importing FastAPI app: {e}")
    sys.exit(1)


def generate_spec():
    filename = sys.argv[1] if len(sys.argv) > 1 else DEFAULT_FILE_NAME

    DOCS_DIR.mkdir(exist_ok=True)
    output_location = DOCS_DIR / filename

    with open(output_location, "w", encoding="utf-8") as f:
        json.dump(app.openapi(), f, indent=2, sort_keys=True)

    print(f"OpenAPI spec exported to: {output_location}")


if __name__ == "__main__":
    generate_spec()
