# Python/FastAPI environment variables
HOST=localhost
PORT={{ app_local_port }}
LOG_FORMAT=human-readable

# API authentication
# Set API_AUTH_ENABLED=true to use DynamoDB-based multi-key auth (requires API_KEYS_TABLE_NAME)
# Leave false for local dev to use the single shared key below instead
API_AUTH_ENABLED=false
API_AUTH_INSECURE_SHARED_KEY=local-dev-key
API_AUTH_CACHE_TTL=300
# API_KEYS_TABLE_NAME={{ app_name }}-api-keys-local

# AWS services (if needed)
# AWS_ACCESS_KEY_ID=<FILL ME IN>
# AWS_SECRET_ACCESS_KEY=<FILL ME IN>
# AWS_DEFAULT_REGION=<FILL ME IN>

# Database (if needed)
# DB_HOST=127.0.0.1
# DB_NAME=app
# DB_USER=app
# DB_PASSWORD=secret123
