# Python/FastAPI Dockerfile
FROM python:3.11-slim

WORKDIR /app

# install curl for health check and libmagic for file type detection
RUN apt-get update && apt-get install -y curl libmagic1 && rm -rf /var/lib/apt/lists/*

RUN pip install uv

COPY pyproject.toml .
COPY src/{{app_name}}/ ./src/{{app_name}}/
RUN uv pip install --system -e ".[dev]"

ENV PYTHONPATH=/app
CMD ["python", "-m", "uvicorn", "{{app_name}}.main:app", "--host", "0.0.0.0", "--port", "8000"]